<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ChessGuru — Opening Explorer</title>
<style>
:root{--bg:#161512;--bg2:#1e1b17;--bg3:#272320;--bg4:#312e28;--border:#3d3830;--text:#bfb89a;--text2:#8a8070;--text3:#5a5248;--accent:#c9a227;--accent2:#a07820;--white:#ede0c8;--green:#4a9c5d;--red:#c04040;--draw:#7a7060;--panel-w:340px}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--text);font-family:'Segoe UI',system-ui,sans-serif;font-size:14px;min-height:100vh;overflow-x:hidden}
nav{background:var(--bg2);border-bottom:1px solid var(--border);padding:0 20px;height:48px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}
.nav-logo{font-size:18px;font-weight:700;color:var(--accent);letter-spacing:-0.5px}
.nav-logo span{color:var(--white);font-weight:400}
.nav-links{display:flex;gap:4px}
.nav-links a{color:var(--text2);text-decoration:none;padding:6px 12px;border-radius:6px;font-size:13px;transition:background .15s,color .15s}
.nav-links a:hover{background:var(--bg3);color:var(--text)}
.nav-links a.active{background:var(--bg4);color:var(--accent)}
.engine-badge{font-size:11px;background:var(--bg4);border:1px solid var(--border);color:var(--text2);padding:3px 8px;border-radius:4px}
.engine-badge.loaded{color:var(--accent);border-color:var(--accent2)}
.app{display:flex;height:calc(100vh - 48px);overflow:hidden}
.eval-bar-wrap{width:20px;background:#0d0b08;border-right:1px solid var(--border);display:flex;flex-direction:column;position:relative;flex-shrink:0}
.eval-bar-white{background:#e8dcc8;width:100%;transition:height .4s cubic-bezier(.4,0,.2,1);position:absolute;top:0}
.board-area{display:flex;flex-direction:column;align-items:center;padding:16px 12px 12px;flex:0 0 auto;min-width:300px;gap:10px;overflow-y:auto}
.player-label{display:flex;align-items:center;gap:8px;width:100%;max-width:520px;font-size:13px;color:var(--text2)}
.dot{width:10px;height:10px;border-radius:50%;border:1px solid var(--border)}
.dot-white{background:#f0e0c0}.dot-black{background:#2a2520}
.player-name{color:var(--text);font-weight:500}
.board-wrap{position:relative;width:100%;max-width:520px;aspect-ratio:1}
#board{width:100%;height:100%;border-radius:2px;overflow:hidden;border:2px solid var(--border)}
.move-history{width:100%;max-width:520px;background:var(--bg2);border:1px solid var(--border);border-radius:6px;padding:8px 10px;min-height:38px;display:flex;flex-wrap:wrap;gap:2px 0;align-items:center;font-size:13px;overflow-x:auto}
.move-pair{display:flex;align-items:center}
.move-num{color:var(--text3);min-width:22px;font-size:12px}
.mv{padding:2px 5px;border-radius:3px;cursor:pointer;color:var(--text);transition:background .1s;font-family:'Courier New',monospace;font-size:13px}
.mv:hover{background:var(--bg4)}.mv.active{background:var(--accent2);color:var(--white)}
.mv-start{color:var(--text3);font-size:12px;padding:2px 5px;cursor:pointer}
.mv-start:hover,.mv-start.active{background:var(--bg4);border-radius:3px}
.board-controls{display:flex;gap:6px;width:100%;max-width:520px;align-items:center}
.ctrl-btn{background:var(--bg3);border:1px solid var(--border);color:var(--text2);padding:6px 12px;border-radius:5px;cursor:pointer;font-size:13px;transition:background .15s,color .15s}
.ctrl-btn:hover{background:var(--bg4);color:var(--text)}
.ctrl-btn.danger{color:var(--red)}.ctrl-btn.danger:hover{background:rgba(192,64,64,.15)}
.spacer{flex:1}
.eval-row{width:100%;max-width:520px;display:flex;align-items:center;gap:8px;font-size:12px;color:var(--text3);min-height:18px}
.eval-score{font-size:16px;font-weight:700;color:var(--white);font-family:monospace;min-width:50px}
.eval-depth{color:var(--text3);font-size:11px}
.bestmove-san{color:var(--accent);font-family:monospace}
.right-panel{width:var(--panel-w);flex-shrink:0;border-left:1px solid var(--border);background:var(--bg2);display:flex;flex-direction:column;overflow:hidden}
.panel-tabs{display:flex;border-bottom:1px solid var(--border);flex-shrink:0}
.ptab{flex:1;padding:10px 0;text-align:center;font-size:12px;color:var(--text2);cursor:pointer;border-bottom:2px solid transparent;transition:color .15s;letter-spacing:.3px}
.ptab:hover{color:var(--text)}.ptab.active{color:var(--accent);border-bottom-color:var(--accent)}
.panel-content{flex:1;overflow-y:auto}
.panel-section{display:none;padding:12px 14px}.panel-section.active{display:block}
.filter-row{display:flex;gap:6px;align-items:center;margin-bottom:10px;flex-wrap:wrap}
.filter-label{font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:.5px;min-width:40px}
.filter-btn{background:var(--bg3);border:1px solid var(--border);color:var(--text2);padding:3px 8px;border-radius:4px;cursor:pointer;font-size:11px;transition:all .15s}
.filter-btn:hover{background:var(--bg4);color:var(--text)}.filter-btn.on{background:var(--accent2);color:var(--white);border-color:var(--accent)}
.source-toggle{display:flex;background:var(--bg3);border:1px solid var(--border);border-radius:5px;overflow:hidden;margin-bottom:12px}
.src-btn{flex:1;padding:6px 0;text-align:center;font-size:12px;color:var(--text2);cursor:pointer;transition:all .15s}
.src-btn.active{background:var(--bg4);color:var(--accent)}
.opening-info{padding:10px 14px;border-bottom:1px solid var(--border);min-height:44px;background:var(--bg);flex-shrink:0;display:flex;align-items:center}
.eco-badge{display:inline-block;background:var(--accent2);color:var(--white);font-size:11px;font-weight:700;padding:2px 6px;border-radius:3px;margin-right:6px;font-family:monospace}
.opening-name{font-size:13px;color:var(--white)}
.opening-placeholder{color:var(--text3);font-size:12px}
.moves-tbl{width:100%;border-collapse:collapse;font-size:12px;margin-bottom:4px}
.moves-tbl th{color:var(--text3);font-weight:400;font-size:10px;text-transform:uppercase;letter-spacing:.5px;padding:4px 6px 6px;text-align:left;border-bottom:1px solid var(--border)}
.moves-tbl th:not(:first-child){text-align:right}
.move-row{cursor:pointer;border-bottom:1px solid rgba(61,56,48,.4);transition:background .1s}
.move-row:hover{background:var(--bg3)}.move-row td{padding:6px;vertical-align:middle}
.move-san{font-family:monospace;font-size:13px;color:var(--white);font-weight:500}
.move-games{color:var(--text2);text-align:right}
.pct-bar-wrap{display:flex;height:6px;border-radius:3px;overflow:hidden;width:80px;margin-left:auto}
.pct-w{background:#d0c090}.pct-d{background:var(--draw)}.pct-b{background:#3a3530;border:1px solid #5a5248}
.pct-cell{padding:6px}
.games-section{margin-top:8px}
.games-label{font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px}
.game-card{background:var(--bg3);border:1px solid var(--border);border-radius:5px;padding:7px 9px;margin-bottom:5px;cursor:pointer;transition:background .1s;text-decoration:none;display:block}
.game-card:hover{background:var(--bg4)}
.game-players{font-size:12px;color:var(--text);display:flex;justify-content:space-between;align-items:center;gap:6px}
.game-player{flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.game-player-b{text-align:right}.game-vs{color:var(--text3);font-size:11px;flex-shrink:0}
.game-meta{font-size:11px;color:var(--text3);margin-top:3px;display:flex;gap:8px}
.game-result-w{color:var(--green);font-weight:700}.game-result-b{color:var(--red);font-weight:700}.game-result-d{color:var(--text2);font-weight:700}
.engine-toggle-row{display:flex;align-items:center;justify-content:space-between;padding:10px 14px;border-bottom:1px solid var(--border);flex-shrink:0}
.toggle-sw{position:relative;width:36px;height:20px;cursor:pointer;display:block}
.toggle-sw input{display:none}
.toggle-track{position:absolute;inset:0;background:var(--bg4);border-radius:10px;border:1px solid var(--border);transition:background .2s}
.toggle-thumb{position:absolute;width:14px;height:14px;background:var(--text2);border-radius:50%;top:2px;left:2px;transition:transform .2s,background .2s}
input:checked~.toggle-track{background:var(--accent2);border-color:var(--accent)}
input:checked~.toggle-thumb{transform:translateX(16px);background:var(--white)}
.engine-label{font-size:13px;color:var(--text)}.engine-tier{font-size:11px;color:var(--text3);margin-top:2px}
.pv-lines{padding:10px 14px}
.pv-line{display:flex;align-items:flex-start;gap:8px;padding:8px 0;border-bottom:1px solid var(--border);font-size:12px}
.pv-line:last-child{border-bottom:none}
.pv-num{color:var(--text3);min-width:14px;font-size:11px}
.pv-eval{min-width:44px;font-family:monospace;font-weight:700;font-size:13px}
.pv-eval.pos{color:var(--white)}.pv-eval.neg{color:var(--text2)}.pv-eval.mate{color:var(--accent)}
.pv-moves{color:var(--text2);font-family:monospace;line-height:1.6;font-size:11px}
.pv-depth{color:var(--text3);font-size:10px;margin-top:2px}
.engine-off-msg{padding:40px 20px;text-align:center;color:var(--text3);font-size:13px;line-height:1.7}
.stat-row{display:flex;gap:2px;height:8px;border-radius:4px;overflow:hidden;margin-bottom:8px}
.stat-legend{display:flex;gap:14px;font-size:11px;color:var(--text3);margin-bottom:8px;flex-wrap:wrap}
.stat-dot{width:8px;height:8px;border-radius:50%;display:inline-block;margin-right:3px}
.explorer-status{padding:20px 14px;text-align:center;color:var(--text3);font-size:12px}
.spinner{display:inline-block;width:16px;height:16px;border:2px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin .7s linear infinite;margin-bottom:6px}
@keyframes spin{to{transform:rotate(360deg)}}
.panel-content::-webkit-scrollbar{width:4px}
.panel-content::-webkit-scrollbar-track{background:transparent}
.panel-content::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}
@media(max-width:900px){:root{--panel-w:280px}.board-area{padding:10px 8px}}
@media(max-width:680px){.app{flex-direction:column;height:auto}.right-panel{width:100%;border-left:none;border-top:1px solid var(--border);height:420px}.eval-bar-wrap{display:none}}
</style>
</head>
<body>
<nav>
  <div class="nav-logo">Chess<span>Guru</span></div>
  <div class="nav-links">
    <a href="/">Puzzles</a>
    <a href="/blindfold">Blindfold</a>
    <a href="/opening" class="active">Opening Explorer</a>
  </div>
  <div class="engine-badge" id="engineBadge">Engine loading...</div>
</nav>
<div class="app">
  <div class="eval-bar-wrap">
    <div class="eval-bar-white" id="evalBarWhite" style="height:50%"></div>
  </div>
  <div class="board-area">
    <div class="player-label"><div class="dot dot-black"></div><span class="player-name">Black</span></div>
    <div class="board-wrap"><div id="board"></div></div>
    <div class="player-label"><div class="dot dot-white"></div><span class="player-name">White</span></div>
    <div class="eval-row">
      <span class="eval-score" id="evalScore"></span>
      <span class="bestmove-san" id="bestMoveSan"></span>
      <span class="eval-depth" id="evalDepth"></span>
    </div>
    <div class="move-history" id="moveHistory">
      <span class="mv-start active" onclick="goToStart()">Start</span>
    </div>
    <div class="board-controls">
      <button class="ctrl-btn" onclick="goToStart()">|&lt;</button>
      <button class="ctrl-btn" onclick="stepBack()">&lt;</button>
      <button class="ctrl-btn" onclick="stepForward()">&gt;</button>
      <button class="ctrl-btn" onclick="goToEnd()">&gt;|</button>
      <div class="spacer"></div>
      <button class="ctrl-btn" onclick="flipBoard()" title="Flip (F)">Flip</button>
      <button class="ctrl-btn danger" onclick="resetBoard()">Reset</button>
    </div>
  </div>
  <div class="right-panel">
    <div class="opening-info" id="openingInfo">
      <span class="opening-placeholder">Play moves to explore openings</span>
    </div>
    <div class="panel-tabs">
      <div class="ptab active" data-tab="explorer" onclick="switchTab('explorer')">Explorer</div>
      <div class="ptab" data-tab="engine" onclick="switchTab('engine')">Engine</div>
    </div>
    <div class="panel-content">
      <div class="panel-section active" id="tab-explorer">
        <div class="source-toggle">
          <div class="src-btn active" id="srcLichess" onclick="setSource('lichess')">Lichess</div>
          <div class="src-btn" id="srcMasters" onclick="setSource('masters')">Masters</div>
        </div>
        <div class="filter-row" id="speedFilters">
          <span class="filter-label">Speed</span>
          <button class="filter-btn on" data-speed="bullet" onclick="toggleFilter(this,'speed')">Bullet</button>
          <button class="filter-btn on" data-speed="blitz" onclick="toggleFilter(this,'speed')">Blitz</button>
          <button class="filter-btn on" data-speed="rapid" onclick="toggleFilter(this,'speed')">Rapid</button>
          <button class="filter-btn on" data-speed="classical" onclick="toggleFilter(this,'speed')">Classical</button>
        </div>
        <div class="filter-row" id="ratingFilters">
          <span class="filter-label">Rating</span>
          <button class="filter-btn" data-rating="1600" onclick="toggleFilter(this,'rating')">1600</button>
          <button class="filter-btn on" data-rating="1800" onclick="toggleFilter(this,'rating')">1800</button>
          <button class="filter-btn on" data-rating="2000" onclick="toggleFilter(this,'rating')">2000</button>
          <button class="filter-btn on" data-rating="2200" onclick="toggleFilter(this,'rating')">2200</button>
          <button class="filter-btn on" data-rating="2500" onclick="toggleFilter(this,'rating')">2500</button>
        </div>
        <div id="explorerContent">
          <div class="explorer-status"><div class="spinner"></div><br>Connecting...</div>
        </div>
      </div>
      <div class="panel-section" id="tab-engine">
        <div class="engine-toggle-row">
          <div>
            <div class="engine-label">Stockfish 17.1</div>
            <div class="engine-tier" id="engineTierLabel">Detecting browser...</div>
          </div>
          <label class="toggle-sw">
            <input type="checkbox" id="engineToggle" onchange="toggleEngine(this.checked)">
            <div class="toggle-track"></div>
            <div class="toggle-thumb"></div>
          </label>
        </div>
        <div id="pvContainer">
          <div class="engine-off-msg">Enable the engine to see Stockfish analysis</div>
        </div>
      </div>
    </div>
  </div>
</div>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/chessboard-js/1.0.0/chessboard-1.0.0.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/chess.js/0.12.0/chess.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/chessboard-js/1.0.0/chessboard-1.0.0.min.js"></script>
<script>
var chess=new Chess(),board=null,boardFlipped=false,moveStack=[],navIdx=-1;
var explorerSource='lichess',explorerAbort=null,explorerRetries=0;
var activeSpeed=new Set(['bullet','blitz','rapid','classical']);
var activeRating=new Set(['1800','2000','2200','2500']);
var sfWorker=null,engineOn=false,engineTier=null,engineReady=false,pvLines={},currentDepth=0;

function _doInit(){
  try {
    board = Chessboard('board', {
      draggable: true,
      position: 'start',
      onDragStart: function(src,pc){
        if(chess.game_over())return false;
        var t=chess.turn();
        if(t==='w'&&pc.search(/^b/)!==-1)return false;
        if(t==='b'&&pc.search(/^w/)!==-1)return false;
      },
      onDrop: function(src,tgt){
        var mv=chess.move({from:src,to:tgt,promotion:'q'});
        if(!mv)return 'snapback';
        moveStack=moveStack.slice(0,navIdx+1);moveStack.push(mv);navIdx=moveStack.length-1;
        afterMove();
      },
      onSnapEnd: function(){board.position(chess.fen());},
      pieceTheme: '/pieces/{piece}.svg',
      orientation: 'white'
    });
    fetchExplorer();
  } catch(e2) { console.error('initBoard failed:', e2); }
  try { initEngine(); } catch(e3) { console.error('initEngine failed:', e3); }

function initBoard(){
  board=Chessboard('board',{
    draggable:true,position:'start',
    onDragStart:function(src,pc){
      if(chess.game_over())return false;
      var t=chess.turn();
      if(t==='w'&&pc.search(/^b/)!==-1)return false;
      if(t==='b'&&pc.search(/^w/)!==-1)return false;
    },
    onDrop:function(src,tgt){
      var mv=chess.move({from:src,to:tgt,promotion:'q'});
      if(!mv)return'snapback';
      moveStack=moveStack.slice(0,navIdx+1);moveStack.push(mv);navIdx=moveStack.length-1;
      afterMove();
    },
    onSnapEnd:function(){board.position(chess.fen());},
    pieceTheme:'/pieces/{piece}.svg',
    orientation:'white'
  });
  fetchExplorer();
}

function goToStart(){chess.reset();navIdx=-1;board.position('start');afterMove();}
function goToEnd(){chess.reset();for(var i=0;i<moveStack.length;i++)chess.move(moveStack[i].san);navIdx=moveStack.length-1;board.position(chess.fen());afterMove();}
function stepBack(){if(navIdx<0)return;navIdx--;chess.reset();for(var i=0;i<=navIdx;i++)chess.move(moveStack[i].san);board.position(navIdx<0?'start':chess.fen());afterMove();}
function stepForward(){if(navIdx>=moveStack.length-1)return;navIdx++;chess.move(moveStack[navIdx].san);board.position(chess.fen());afterMove();}
function goToMove(idx){navIdx=idx;chess.reset();for(var i=0;i<=navIdx;i++)chess.move(moveStack[i].san);board.position(navIdx<0?'start':chess.fen());afterMove();}
function flipBoard(){boardFlipped=!boardFlipped;board.flip();}
function resetBoard(){chess.reset();moveStack=[];navIdx=-1;board.position('start');pvLines={};afterMove();}
function afterMove(){renderHistory();fetchExplorer();if(engineOn&&engineReady)analyzePos();}

function renderHistory(){
  var el=document.getElementById('moveHistory');
  var h='<span class="mv-start'+(navIdx===-1?' active':'')+'" onclick="goToStart()">Start</span>';
  for(var i=0;i<moveStack.length;i+=2){
    var n=Math.floor(i/2)+1;
    h+='<span class="move-pair"><span class="move-num">'+n+'.</span>';
    h+='<span class="mv'+(navIdx===i?' active':'')+'" onclick="goToMove('+i+')">'+moveStack[i].san+'</span>';
    if(moveStack[i+1])h+='<span class="mv'+(navIdx===i+1?' active':'')+'" onclick="goToMove('+(i+1)+')">'+moveStack[i+1].san+'</span>';
    h+='</span>';
  }
  el.innerHTML=h;
  var a=el.querySelector('.active');if(a)a.scrollIntoView({block:'nearest',behavior:'smooth'});
}

function getPlay(){
  var moves=[],tmp=new Chess();
  for(var i=0;i<=navIdx&&i<moveStack.length;i++){var mv=tmp.move(moveStack[i].san);if(mv)moves.push(mv.from+mv.to+(mv.promotion||''));}
  return moves.join(',');
}

function fetchExplorer(){
  if(explorerAbort){explorerAbort.abort();explorerAbort=null;}
  explorerRetries=0;doFetch();
}

function doFetch(){
  var ctrl=new AbortController();explorerAbort=ctrl;
  var p=new URLSearchParams();
  p.set('variant','standard');
  p.set('fen','rnbqkbnr/pppppppp/8/8/8/8/PPPPPPPP/RNBQKBNR w KQkq - 0 1');
  p.set('moves','12');p.set('topGames','4');p.set('recentGames','4');
  var play=getPlay();if(play)p.set('play',play);
  if(explorerSource==='lichess'){
    var sp=Array.from(activeSpeed).join(',');var rt=Array.from(activeRating).join(',');
    if(sp)p.set('speeds',sp);if(rt)p.set('ratings',rt);
  }
  document.getElementById('explorerContent').innerHTML='<div class="explorer-status"><div class="spinner"></div><br>Loading...</div>';
  fetch('https://explorer.lichess.ovh/'+explorerSource+'?'+p.toString(),{signal:ctrl.signal})
    .then(function(r){if(r.status===429)throw new Error('rate');if(!r.ok)throw new Error('http');return r.json();})
    .then(renderExplorer)
    .catch(function(e){
      if(e.name==='AbortError')return;
      if(e.message==='rate'&&explorerRetries<3){
        explorerRetries++;var d=explorerRetries*4000;
        document.getElementById('explorerContent').innerHTML='<div class="explorer-status"><div class="spinner"></div><br>Rate limited - retry '+explorerRetries+'/3 in '+(d/1000)+'s...</div>';
        setTimeout(doFetch,d);
      } else {
        document.getElementById('explorerContent').innerHTML='<div class="explorer-status">Explorer unavailable.<br><button class="ctrl-btn" onclick="fetchExplorer()" style="margin:8px auto">Retry</button></div>';
      }
    });
}

function renderExplorer(data){
  var info=document.getElementById('openingInfo');
  if(data.opening&&data.opening.name){
    info.innerHTML='<span class="eco-badge">'+(data.opening.eco||'')+'</span><span class="opening-name">'+esc(data.opening.name)+'</span>';
  } else {
    info.innerHTML='<span class="opening-placeholder">'+(navIdx<0?'Play moves to explore openings':'Position not in opening book')+'</span>';
  }
  var total=(data.white||0)+(data.draws||0)+(data.black||0);
  var el=document.getElementById('explorerContent');
  if(!total&&(!data.moves||!data.moves.length)){el.innerHTML='<div class="explorer-status">No games found.</div>';return;}
  var h='';
  if(total>0){
    var wp=Math.round(data.white/total*100),dp=Math.round(data.draws/total*100);
    h+='<div style="margin-bottom:10px"><div class="stat-row"><div class="pct-w" style="width:'+wp+'%"></div><div class="pct-d" style="width:'+dp+'%"></div><div class="pct-b" style="flex:1"></div></div>';
    h+='<div class="stat-legend"><span><span class="stat-dot" style="background:#d0c090"></span>'+wp+'% W</span><span><span class="stat-dot" style="background:#7a7060"></span>'+dp+'% D</span><span><span class="stat-dot" style="background:#3a3530;border:1px solid #5a5248"></span>'+(100-wp-dp)+'% B</span><span style="margin-left:auto">'+fmtN(total)+' games</span></div></div>';
  }
  if(data.moves&&data.moves.length){
    h+='<table class="moves-tbl"><thead><tr><th>Move</th><th>Games</th><th>W/D/B</th></tr></thead><tbody>';
    data.moves.forEach(function(mv){
      var t=(mv.white||0)+(mv.draws||0)+(mv.black||0);
      var w2=t?Math.round(mv.white/t*100):0,d2=t?Math.round(mv.draws/t*100):0;
      h+='<tr class="move-row" onclick="playMove(this.dataset.uci)" data-uci=""+mv.uci+"><td><span class="move-san">'+mv.san+'</span></td><td class="move-games">'+fmtN(t)+'</td><td class="pct-cell"><div class="pct-bar-wrap"><div class="pct-w" style="width:'+w2+'%"></div><div class="pct-d" style="width:'+d2+'%"></div><div class="pct-b" style="flex:1"></div></div></td></tr>';
    });
    h+='</tbody></table>';
  }
  var games=[],seen={};
  ((data.topGames||[]).concat(data.recentGames||[])).forEach(function(g){if(g.id&&!seen[g.id]){seen[g.id]=1;games.push(g);}});
  if(games.length){
    h+='<div class="games-section"><div class="games-label">'+(explorerSource==='masters'?'Notable games':'Recent games')+'</div>';
    games.slice(0,6).forEach(function(g){
      var wn=(g.white&&g.white.name)?g.white.name:'?';
      var bn=(g.black&&g.black.name)?g.black.name:'?';
      var wr=g.white&&g.white.rating?' ('+g.white.rating+')':'';
      var br=g.black&&g.black.rating?' ('+g.black.rating+')':'';
      var rc=g.winner==='white'?'game-result-w':g.winner==='black'?'game-result-b':'game-result-d';
      var rt=g.winner==='white'?'1-0':g.winner==='black'?'0-1':'1/2-1/2';
      var yr=g.month?g.month.slice(0,4):(g.year||'');
      h+='<a class="game-card" href="https://lichess.org/'+g.id+'" target="_blank" rel="noopener"><div class="game-players"><span class="game-player">'+esc(wn+wr)+'</span><span class="game-vs">vs</span><span class="game-player game-player-b">'+esc(bn+br)+'</span></div><div class="game-meta"><span class="'+rc+'">'+rt+'</span>'+(g.speed?'<span>'+g.speed+'</span>':'')+(yr?'<span>'+yr+'</span>':'')+'</div></a>';
    });
    h+='</div>';
  }
  el.innerHTML=h;
}

function playMove(uci){
  var mv=chess.move({from:uci.slice(0,2),to:uci.slice(2,4),promotion:uci[4]||'q'});
  if(!mv)return;
  moveStack=moveStack.slice(0,navIdx+1);moveStack.push(mv);navIdx=moveStack.length-1;
  board.position(chess.fen());afterMove();
}

function setSource(src){
  explorerSource=src;
  document.getElementById('srcLichess').classList.toggle('active',src==='lichess');
  document.getElementById('srcMasters').classList.toggle('active',src==='masters');
  document.getElementById('speedFilters').style.display=src==='lichess'?'flex':'none';
  document.getElementById('ratingFilters').style.display=src==='lichess'?'flex':'none';
  fetchExplorer();
}
function toggleFilter(btn,type){
  var val=btn.dataset.speed||btn.dataset.rating,s=type==='speed'?activeSpeed:activeRating;
  if(s.has(val)){s.delete(val);btn.classList.remove('on');}else{s.add(val);btn.classList.add('on');}
  fetchExplorer();
}
function switchTab(name){
  document.querySelectorAll('.ptab').forEach(function(t){t.classList.toggle('active',t.dataset.tab===name);});
  document.querySelectorAll('.panel-section').forEach(function(s){s.classList.toggle('active',s.id==='tab-'+name);});
}

function detectTier(){
  var wasm=typeof WebAssembly==='object'&&WebAssembly.validate(Uint8Array.of(0x0,0x61,0x73,0x6d,0x01,0x00,0x00,0x00));
  if(!wasm)return'asm';
  var shared=(function(){try{if(typeof SharedArrayBuffer!=='function')return false;if(typeof Atomics!=='object')return false;var m=new WebAssembly.Memory({shared:true,initial:8,maximum:16});if(!(m.buffer instanceof SharedArrayBuffer))return false;window.postMessage(m,'*');return true;}catch(e){return false;}})();
  return(shared&&(navigator.deviceMemory||4)>=2)?'lite-multi':'lite-single';
}

var TIER_FILES={'lite-multi':'/js/sf/stockfish-nnue-17.1-lite.js','lite-single':'/js/sf/stockfish-nnue-17.1-lite-single.js','asm':'/js/sf/stockfish.js'};
var TIER_LABELS={'lite-multi':'SF 17.1 multi-thread','lite-single':'SF 17.1 single-thread','asm':'SF JS fallback'};

function initEngine(){
  engineTier=detectTier();
  document.getElementById('engineTierLabel').textContent=TIER_LABELS[engineTier]||engineTier;
  tryLoadWorker(engineTier);
}
function tryLoadWorker(tier){
  try{
    sfWorker=new Worker(TIER_FILES[tier]);
    sfWorker.onmessage=function(e){handleSF(e.data);};
    sfWorker.onerror=function(){
      sfWorker=null;
      if(tier==='lite-multi')tryLoadWorker('lite-single');
      else if(tier==='lite-single')tryLoadWorker('asm');
      else document.getElementById('engineTierLabel').textContent='Unavailable - place SF files in /js/sf/';
    };
    sfWorker.postMessage('uci');
  }catch(e){
    if(tier==='lite-multi')tryLoadWorker('lite-single');
    else if(tier==='lite-single')tryLoadWorker('asm');
    else document.getElementById('engineTierLabel').textContent='Engine unavailable';
  }
}
function handleSF(line){
  if(line==='uciok'){sfWorker.postMessage('setoption name MultiPV value 3');if(engineTier==='lite-multi'){var th=Math.max(1,Math.min((navigator.hardwareConcurrency||2)-1,4));sfWorker.postMessage('setoption name Threads value '+th);}sfWorker.postMessage('isready');return;}
  if(line==='readyok'){engineReady=true;document.getElementById('engineBadge').textContent='Stockfish 17.1 - '+(TIER_LABELS[engineTier]||engineTier);document.getElementById('engineBadge').classList.add('loaded');document.getElementById('engineTierLabel').textContent=(TIER_LABELS[engineTier]||engineTier)+' loaded';if(engineOn)analyzePos();return;}
  if(line.startsWith('info')&&line.includes('score')&&line.includes(' pv ')){
    var mpv=parseInt(tok(line,'multipv'))||1,depth=parseInt(tok(line,'depth'))||0;
    var cp=tok(line,'cp'),mate=tok(line,'mate');
    var pvRaw=(line.split(' pv ')[1]||'').trim().split(' ').slice(0,8);
    var es='',ec='pos';
    if(mate!==null){var mn=parseInt(mate);es=(mn>0?'+':'')+' M'+Math.abs(mn);ec='mate';}
    else if(cp!==null){var cn=parseInt(cp)/100;es=(cn>=0?'+':'')+cn.toFixed(1);ec=cn>=0?'pos':'neg';}
    pvLines[mpv]={eval:es,evalClass:ec,pv:uci2san(pvRaw),depth:depth};currentDepth=depth;
    if(mpv===1){var cpv=cp!==null?parseInt(cp):(mate!==null?(parseInt(mate)>0?9999:-9999):0);var pct=Math.max(5,Math.min(95,50+cpv/1000*45));document.getElementById('evalBarWhite').style.height=pct+'%';document.getElementById('evalScore').textContent=es;document.getElementById('evalDepth').textContent='depth '+depth;}
    if(engineOn)renderPV();return;
  }
  if(line.startsWith('bestmove')&&engineOn){var bm=line.split(' ')[1];if(bm&&bm!=='(none)'){var tmp=new Chess(chess.fen());var bmmv=tmp.move({from:bm.slice(0,2),to:bm.slice(2,4),promotion:bm[4]||'q'});document.getElementById('bestMoveSan').textContent=bmmv?'Best: '+bmmv.san:'';}renderPV();}
}
function tok(line,t){var pts=line.split(' '),idx=pts.indexOf(t);if(idx===-1||idx>=pts.length-1)return null;var n=pts[idx+1];var kw=['depth','seldepth','time','nodes','multipv','score','cp','mate','lowerbound','upperbound','currmove','currmovenumber','hashfull','nps','tbhits','pv'];if(kw.indexOf(n)!==-1)return null;return n;}
function uci2san(ucis){var tmp=new Chess(chess.fen()),sans=[];for(var i=0;i<ucis.length;i++){var u=ucis[i];if(!u||u.length<4)break;var mv=tmp.move({from:u.slice(0,2),to:u.slice(2,4),promotion:u[4]||'q'});if(!mv)break;sans.push(mv.san);}return sans.join(' ');}
function analyzePos(){if(!sfWorker||!engineReady)return;pvLines={};sfWorker.postMessage('stop');sfWorker.postMessage('position fen '+chess.fen());sfWorker.postMessage('go depth 25');}
function toggleEngine(on){
  engineOn=on;
  if(on){if(!sfWorker)initEngine();else if(engineReady)analyzePos();renderPV();}
  else{if(sfWorker&&engineReady)sfWorker.postMessage('stop');document.getElementById('pvContainer').innerHTML='<div class="engine-off-msg">Enable the engine to see Stockfish analysis</div>';document.getElementById('evalScore').textContent='';document.getElementById('evalDepth').textContent='';document.getElementById('bestMoveSan').textContent='';document.getElementById('evalBarWhite').style.height='50%';}
}
function renderPV(){
  if(!engineOn)return;
  var c=document.getElementById('pvContainer');
  if(!Object.keys(pvLines).length){c.innerHTML='<div class="engine-off-msg">Analyzing...</div>';return;}
  var h='<div class="pv-lines">';
  for(var i=1;i<=3;i++){var l=pvLines[i];if(!l)continue;h+='<div class="pv-line"><span class="pv-num">'+i+'</span><span class="pv-eval '+l.evalClass+'">'+l.eval+'</span><div><div class="pv-moves">'+esc(l.pv)+'</div><div class="pv-depth">depth '+l.depth+'</div></div></div>';}
  h+='</div>';c.innerHTML=h;
}
function fmtN(n){if(n>=1e6)return(n/1e6).toFixed(1)+'M';if(n>=1e3)return(n/1e3).toFixed(0)+'K';return''+n;}
function esc(s){if(!s)return'';return(''+s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
document.addEventListener('keydown',function(e){
  if(['INPUT','TEXTAREA'].indexOf(e.target.tagName)!==-1)return;
  if(e.key==='ArrowLeft'){e.preventDefault();stepBack();}
  if(e.key==='ArrowRight'){e.preventDefault();stepForward();}
  if(e.key==='ArrowUp'){e.preventDefault();goToStart();}
  if(e.key==='ArrowDown'){e.preventDefault();goToEnd();}
  if(e.key==='f'||e.key==='F')flipBoard();
});
</script>
</body>
</html>